{
	"name": "electrobun-react-tailwind-vite",
	"version": "1.0.0",
	"description": "Electrobun app with React, Tailwind CSS, and Vite HMR",
	"scripts": {
		"start": "vite build && electrobun dev",
		"dev": "electrobun dev --watch",
		"dev:hmr": "concurrently \"bun run hmr\" \"bun run start\"",
		"hmr": "vite --port 5173",
		"build:canary": "vite build && electrobun build --env=canary"
	},
	"dependencies": {
		"@fontsource-variable/inter": "^5.2.8",
		"@gravity/ui": "workspace:*",
		"@hugeicons/core-free-icons": "^4.1.1",
		"@hugeicons/react": "^1.1.6",
		"@tailwindcss/postcss": "^4.2.4",
		"@tailwindcss/vite": "^4.2.4",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"electrobun": "1.16.0",
		"radix-ui": "^1.4.3",
		"react": "^19.2.3",
		"react-dom": "^19.2.3",
		"react-router-dom": "^6.23.1",
		"shadcn": "^4.6.0",
		"tailwind-merge": "^3.5.0",
		"tw-animate-css": "^1.4.0"
	},
	"devDependencies": {
		"@types/bun": "latest",
		"@types/react": "^19.2.10",
		"@types/react-dom": "^19.2.3",
		"@vitejs/plugin-react": "^4.3.4",
		"autoprefixer": "^10.4.20",
		"concurrently": "^9.1.0",
		"postcss": "^8.5.14",
		"tailwindcss": "^4.2.4",
		"typescript": "^5.7.2",
		"vite": "^6.0.3"
	}
}
